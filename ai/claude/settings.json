{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "includeCoAuthoredBy": true,
  "autoMemoryEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(herd php artisan:*)",
      "Bash(pest:*)",
      "Read",
      "Edit",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/format.sh"
          }
        ]
      }
    ]
  }
}
