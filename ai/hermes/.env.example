# Hermes Agent environment — copy to `.env` in this directory and fill in.
# `.env` is git-ignored. Do NOT commit real keys.

# --- Model providers (set the ones you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Local models via the bundled Ollama service
OLLAMA_HOST=http://ollama:11434
# HERMES_DEFAULT_MODEL=ollama/llama3.1

# --- Gateway channels (enable the ones you want the agent reachable on) ---
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# --- Gateway ---
HERMES_PORT=8787
