{
  "LOG": false,
  "API_TIMEOUT_MS": 600000,
  "Providers": [
    {
      "name": "zai",
      "api_base_url": "https://api.z.ai/api/anthropic/v1/messages",
      "api_key": "$ZAI_API_KEY",
      "models": ["glm-5.2", "glm-4.7", "glm-5-turbo", "glm-4.5-air"],
      "transformer": { "use": ["Anthropic"] }
    },
    {
      "name": "ornith",
      "api_base_url": "http://localhost:11434/v1/chat/completions",
      "api_key": "ollama",
      "models": ["ornith"],
      "transformer": { "use": ["reasoning"] }
    }
  ],
  "Router": {
    "default": "zai,glm-4.7",
    "background": "zai,glm-4.5-air",
    "think": "zai,glm-5.2",
    "longContext": "zai,glm-5.2",
    "longContextThreshold": 60000,
    "webSearch": "zai,glm-5.2"
  }
}
