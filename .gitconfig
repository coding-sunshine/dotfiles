# Global git config — symlinked to ~/.gitconfig by fresh.sh.
# Edit [user] below to your own name/email.

[user]
	name = Hardik Shah
	email = mail.hardikshah@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub

[core]
	excludesfile = ~/.dotfiles/.gitignore_global
	pager = delta
	editor = zed --wait

# Sign commits with your SSH key (the one ssh.sh generates). No GPG/1Password
# needed. Add the same public key to GitHub as a "Signing Key" to get the
# "Verified" badge: https://github.com/settings/keys
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = current

[pull]
	rebase = true

[rebase]
	autostash = true
	autosquash = true

[fetch]
	prune = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false

[column]
	ui = auto

[branch]
	sort = -committerdate

[help]
	autocorrect = prompt
