// Parallel-agents layout: a control pane on the left and a 2x2 grid of agent
// panes on the right. Launch with: `zellij --layout agents`
// Pair this with `gwt` so each agent pane runs in its own git worktree.
layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }
    pane split_direction="vertical" {
        pane size="25%" name="control"
        pane split_direction="horizontal" {
            pane split_direction="vertical" {
                pane name="agent-1"
                pane name="agent-2"
            }
            pane split_direction="vertical" {
                pane name="agent-3"
                pane name="agent-4"
            }
        }
    }
    pane size=2 borderless=true {
        plugin location="zellij:status-bar"
    }
}
