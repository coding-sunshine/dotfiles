// Zed settings (~/.config/zed/settings.json)
// Docs: https://zed.dev/docs/configuring-zed
{
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "session": {
    "trust_all_worktrees": true
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 14,
  "format_on_save": "on",
  "tab_size": 2,
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "agent": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-8"
    }
  }
}
