# Copy to ~/.env (git-ignored). Loaded automatically by .zshrc.
# Fill in only the keys you actually use.

# --- AI agent provider keys ---
# ANTHROPIC_API_KEY also bills unattended/headless runs (claude-auto, Ralph) to
# the API/Agent-SDK budget instead of the interactive subscription caps.
export ANTHROPIC_API_KEY=""
export OPENAI_API_KEY=""
export GEMINI_API_KEY=""      # Google AI Studio key (AIza…) for the Gemini API/CLI — NOT the AI Pro app subscription

# --- GitHub (used by the github MCP server) ---
export GITHUB_PERSONAL_ACCESS_TOKEN=""

# --- MCP servers ---
export CONTEXT7_API_KEY=""    # optional: raises Context7 rate limits
export COMPOSIO_API_KEY=""    # set to enable the (heavy) composio MCP; leave blank to keep it off

# Note: cavemem (persistent memory) runs fully local by default — no key needed.

# --- Anything else machine-local (DB creds, tokens, etc.) ---
